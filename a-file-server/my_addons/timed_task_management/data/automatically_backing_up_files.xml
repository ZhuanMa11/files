<?xml version="1.0" encoding="utf-8"?>
<dtcloud>
    <data>
        <record forcecreate="True" id="automatically_backing_up_files_template" model="ir.cron">
            <field name="name">自动备份文件</field>
            <field name="model_id" ref="model_backing_up_files_task"/>
            <field name="state">code</field>
            <field name="code">model.backup_file()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
        </record>

        <record forcecreate="True" id="clear_honor_files_template" model="ir.cron">
            <field name="name">清除冗余备份文件</field>
            <field name="model_id" ref="model_backing_up_files_task"/>
            <field name="state">code</field>
            <field name="code">model.clear_honor_files()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
        </record>
    </data>
</dtcloud>